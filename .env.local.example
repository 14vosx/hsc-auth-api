# HSC Auth API — Local environment template
# Copie para: .env.local

NODE_ENV=development
PORT=3000
AUTH_API_PUBLIC_URL=http://127.0.0.1:3000

# MariaDB local via Docker (compose)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=hsc_auth
DB_USER=hsc
DB_PASS=hsc

# Frontend local (ajuste se necessário)
ALLOWED_ORIGIN=http://localhost:5173

# Admin (somente local; em prod vem do /opt/hsc/hsc-auth-api/.env)
ADMIN_KEY=dev-admin-key

# Internal APIs and Steam profile cache
INTERNAL_API_KEY=
STEAM_API_KEY=
STEAM_PROFILE_CACHE_TTL_SECONDS=86400
STEAM_API_TIMEOUT_SECONDS=8

# Player Bunker local artifacts and optional Static API v2 profile enrichment
PLAYER_BUNKER_ARTIFACT_ROOT=
PLAYER_BUNKER_ACTIVE_SEASON_SLUG=
PLAYER_BUNKER_STATIC_API_BASE_URL=http://127.0.0.1:8080/api/cs2/v2
PLAYER_BUNKER_STATIC_API_TIMEOUT_MS=1500

# Uploads locais controlados pela Auth API
UPLOAD_DIR=./var/uploads
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_PUBLIC_BASE_URL=http://127.0.0.1:3000
UPLOAD_MAX_BYTES=2097152
